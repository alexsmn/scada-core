{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "c:/tools/ninja/ninja.exe",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "static-analysis",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_CPPCHECK": "C:/Program Files/Cppcheck/cppcheck.exe;--enable=warning,performance,portability;--inline-suppr;--suppressions-list=${sourceDir}/cppcheck-suppressions.txt;--error-exitcode=1",
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy;-checks=-*,bugprone-*,performance-*,-bugprone-easily-swappable-parameters;-header-filter=.*"
      }
    },
    {
      "name": "ninja",
      "displayName": "Ninja Multi-Config",
      "description": "Build with Ninja Multi-Config and vcpkg toolchain",
      "inherits": "base",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "ninja-analysis",
      "displayName": "Ninja with Static Analysis",
      "description": "Build with Ninja, cppcheck, and clang-tidy",
      "inherits": ["ninja", "static-analysis"],
      "binaryDir": "${sourceDir}/build-analysis"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "ninja",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "ninja",
      "configuration": "Release"
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "configurePreset": "ninja",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "analysis-debug",
      "displayName": "Debug with Static Analysis",
      "configurePreset": "ninja-analysis",
      "configuration": "Debug"
    },
    {
      "name": "analysis-release",
      "displayName": "Release with Static Analysis",
      "configurePreset": "ninja-analysis",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "displayName": "Debug Tests",
      "configurePreset": "ninja",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "displayName": "Release Tests",
      "configurePreset": "ninja",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
