{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja",
      "displayName": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "deps": "$env{THIRD_PARTY}",
        "BUILD_NUMBER": "0",
        "OUTPUT_DIR": "build/${presetName}/bin",
        "CMAKE_MODULE_PATH": "${sourceDir};$env{THIRD_PARTY}/net;$env{THIRD_PARTY}/chromebase;$env{THIRD_PARTY}/iec60870;$env{THIRD_PARTY}/iec61850pp;$env{THIRD_PARTY}/sql;$env{THIRD_PARTY}/OPCFoundation;$env{THIRD_PARTY}/promise.hpp"
      }
    }
  ]
}
