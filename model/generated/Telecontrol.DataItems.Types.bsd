<opc:TypeDictionary
  xmlns:scada="http://telecontrol.ru/opcua/scada"
  xmlns:history="http://telecontrol.ru/opcua/history"
  xmlns:opc="http://opcfoundation.org/BinarySchema/"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:ua="http://opcfoundation.org/UA/"
  xmlns:tns="http://telecontrol.ru/opcua/data_items"
  DefaultByteOrder="LittleEndian"
  TargetNamespace="http://telecontrol.ru/opcua/data_items"
>
  <opc:Import Namespace="http://opcfoundation.org/UA/" Location="Opc.Ua.BinarySchema.bsd"/>
  <opc:Import Namespace="http://telecontrol.ru/opcua/scada" Location="Telecontrol.Scada.BinarySchema.bsd"/>
  <opc:Import Namespace="http://telecontrol.ru/opcua/history" Location="Telecontrol.History.BinarySchema.bsd"/>

  <opc:EnumeratedType Name="AnalogConversionDataType" LengthInBits="32">
    <opc:EnumeratedValue Name="None" Value="0" />
    <opc:EnumeratedValue Name="Linear" Value="1" />
  </opc:EnumeratedType>

  <opc:EnumeratedType Name="SimulationFunctionDataType" LengthInBits="32">
    <opc:EnumeratedValue Name="Random" Value="0" />
    <opc:EnumeratedValue Name="Ramp" Value="1" />
    <opc:EnumeratedValue Name="Step" Value="2" />
    <opc:EnumeratedValue Name="Sin" Value="3" />
    <opc:EnumeratedValue Name="Cos" Value="4" />
  </opc:EnumeratedType>

</opc:TypeDictionary>