<?xml version="1.0" encoding="utf-8" ?>
<opc:ModelDesign
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema"
	xmlns:opc="http://opcfoundation.org/UA/ModelDesign.xsd"
	xmlns:ua="http://opcfoundation.org/UA/"
	xmlns:uax="http://opcfoundation.org/UA/2008/02/Types.xsd"
  xmlns:scada="http://telecontrol.ru/opcua/scada"
	xmlns="http://telecontrol.ru/opcua/devices"
	TargetNamespace="http://telecontrol.ru/opcua/devices"
>
  <opc:Namespaces>
    <opc:Namespace Name="OpcUa" Prefix="Opc.Ua" XmlNamespace="http://opcfoundation.org/UA/2008/02/Types.xsd">http://opcfoundation.org/UA/</opc:Namespace>
    <opc:Namespace Name="TelecontrolScada" Prefix="Telecontrol.Scada" XmlPrefix="scada" FilePath="scada_model">http://telecontrol.ru/opcua/scada</opc:Namespace>
    <opc:Namespace Name="TelecontrolDevices" Prefix="Telecontrol.Devices">http://telecontrol.ru/opcua/devices</opc:Namespace>
  </opc:Namespaces>

  <opc:Object SymbolicName="Devices" TypeDefinition="ua:FolderType">
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>ua:Organizes</opc:ReferenceType>
        <opc:TargetId>ua:ObjectsFolder</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:Object>

  <opc:Method SymbolicName="DeviceInterrogateMethodType" ModellingRule="Mandatory">
    <!-- opc:InputArguments>
      <opc:Argument Name="Name" DataType="ua:String">
        <opc:Description>The name of the controller to create.</opc:Description>
      </opc:Argument>
    </opc:InputArguments>
    <opc:OutputArguments>
      <opc:Argument Name="NodeId" DataType="ua:NodeId">
        <opc:Description>The NodeId for the controller that was created</opc:Description>
      </opc:Argument>
    </opc:OutputArguments -->
  </opc:Method>

  <opc:Method SymbolicName="DeviceSyncClockMethodType" ModellingRule="Mandatory" />

  <opc:Method SymbolicName="DeviceSelectMethodType" ModellingRule="Mandatory" />

  <opc:Method SymbolicName="DeviceWriteMethodType" ModellingRule="Mandatory" />

  <opc:Method SymbolicName="DeviceWriteParamMethodType" ModellingRule="Mandatory" />

  <opc:Method SymbolicName="DeviceInterrogateChannelMethodType" ModellingRule="Mandatory" />

  <opc:ObjectType SymbolicName="DeviceType" BaseType="ua:BaseObjectType">
    <opc:Children>
      <opc:Property SymbolicName="Disabled" DataType="ua:Boolean" />
      <opc:Variable SymbolicName="Online" TypeDefinition="ua:BaseDataVariableType" DataType="ua:Boolean" />
      <opc:Variable SymbolicName="Enabled" TypeDefinition="ua:BaseDataVariableType" DataType="ua:Boolean" />
      <opc:Method SymbolicName="Interrogate" TypeDefinition="DeviceInterrogateMethodType"></opc:Method>
      <opc:Method SymbolicName="InterrogateChannel" TypeDefinition="DeviceInterrogateChannelMethodType"></opc:Method>
      <opc:Method SymbolicName="SyncClock" TypeDefinition="DeviceSyncClockMethodType"></opc:Method>
      <opc:Method SymbolicName="Select" TypeDefinition="DeviceSelectMethodType"></opc:Method>
      <opc:Method SymbolicName="Write" TypeDefinition="DeviceWriteMethodType"></opc:Method>
      <opc:Method SymbolicName="WriteParam" TypeDefinition="DeviceWriteParamMethodType"></opc:Method>
    </opc:Children>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="LinkType" BaseType="DeviceType">
    <opc:Children>
      <opc:Property SymbolicName="Transport" DataType="ua:String" />
      <opc:Variable SymbolicName="ConnectCount" TypeDefinition="ua:BaseDataVariableType" DataType="ua:UInt32" />
      <opc:Variable SymbolicName="ActiveConnections" TypeDefinition="ua:BaseDataVariableType" DataType="ua:UInt32" />
      <opc:Variable SymbolicName="MessagesOut" TypeDefinition="ua:BaseDataVariableType" DataType="ua:UInt32" />
      <opc:Variable SymbolicName="MessagesIn" TypeDefinition="ua:BaseDataVariableType" DataType="ua:UInt32" />
      <opc:Variable SymbolicName="BytesOut" TypeDefinition="ua:BaseDataVariableType" DataType="ua:UInt32" />
      <opc:Variable SymbolicName="BytesIn" TypeDefinition="ua:BaseDataVariableType" DataType="ua:UInt32" />
    </opc:Children>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>Devices</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="DeviceWatchEventType" BaseType="ua:BaseEventType">
    <opc:Description>Device watch event.</opc:Description>
    <!-- opc:Children>
      <opc:Property SymbolicName="Temperature" DataType="ua:Double"></opc:Property>
      <opc:Property SymbolicName="State" DataType="ua:Int32" AccessLevel="ReadWrite" />
    </opc:Children -->
  </opc:ObjectType>

  <!-- IEC-60870 Devices -->

  <opc:DataType SymbolicName="Iec60870ProtocolDataType" BaseType="ua:Enumeration">
    <opc:Fields>
      <opc:Field Name="IEC-60870-104" Identifier="0" />
      <opc:Field Name="IEC-60870-101" Identifier="1" />
    </opc:Fields>
  </opc:DataType>

  <opc:DataType SymbolicName="Iec60870ModeDataType" BaseType="ua:Enumeration">
    <opc:Fields>
      <opc:Field Name="Client" Identifier="0" />
      <opc:Field Name="Server" Identifier="1" />
      <opc:Field Name="Passive Client" Identifier="2" />
    </opc:Fields>
  </opc:DataType>

  <opc:ObjectType SymbolicName="Iec60870LinkType" BaseType="LinkType">
    <opc:Children>
      <opc:Property SymbolicName="Protocol" DataType="Iec60870ProtocolDataType" />
      <opc:Property SymbolicName="Mode" DataType="ua:UInt32" />
      <opc:Property SymbolicName="SendQueueSize" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>12</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="ReceiveQueueSize" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>8</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="ConnectTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>30</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="ConfirmationTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>5</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="TerminationTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>20</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="DeviceAddressSize" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>2</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="COTSize" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>2</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="InfoAddressSize" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>3</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="DataCollection" DataType="ua:Boolean">
        <opc:DefaultValue>
          <uax:Boolean>true</uax:Boolean>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="SendRetryCount" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>0</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="CRCProtection" DataType="ua:Boolean">
        <opc:DefaultValue>
          <uax:Boolean>false</uax:Boolean>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="SendTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>5</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="ReceiveTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>10</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="IdleTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>30</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="AnonymousMode" DataType="ua:Boolean">
        <opc:DefaultValue>
          <uax:Boolean>false</uax:Boolean>
        </opc:DefaultValue>
      </opc:Property>
    </opc:Children>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="Iec60870DeviceType" BaseType="DeviceType">
    <opc:Children>
      <opc:Property SymbolicName="Address" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>1</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="LinkAddress" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>1</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="StartupInterrogation" DataType="ua:Boolean">
        <opc:DefaultValue>
          <uax:Boolean>true</uax:Boolean>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="InterrogationPeriod" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>0</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="StartupClockSync" DataType="ua:Boolean">
        <opc:DefaultValue>
          <uax:Boolean>true</uax:Boolean>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="ClockSyncPeriod" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>0</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="UtcTime" DataType="ua:Boolean" />
      <!-- TODO: Array -->
      <opc:Property SymbolicName="InterrogationPeriodGroup1" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup2" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup3" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup4" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup5" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup6" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup7" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup8" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup9" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup10" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup11" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup12" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup13" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup14" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup15" DataType="ua:UInt32" />
      <opc:Property SymbolicName="InterrogationPeriodGroup16" DataType="ua:UInt32" />
    </opc:Children>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>Iec60870LinkType</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <!-- IEC-61850 Protocol -->

  <opc:ObjectType SymbolicName="Iec61850LogicalNodeType" BaseType="ua:BaseObjectType">
  </opc:ObjectType>

  <opc:VariableType SymbolicName="Iec61850DataVariableType" BaseType="ua:BaseVariableType">
  </opc:VariableType>

  <opc:ObjectType SymbolicName="Iec61850ControlObjectType" BaseType="ua:BaseObjectType">
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="Iec61850DeviceType" BaseType="DeviceType">
    <opc:Children>
      <opc:Object SymbolicName="Model" TypeDefinition="Iec61850LogicalNodeType" />
      <opc:Property SymbolicName="Host" DataType="ua:String" />
      <opc:Property SymbolicName="Port" DataType="ua:UInt16">
        <opc:DefaultValue>
          <uax:UInt16>102</uax:UInt16>
        </opc:DefaultValue>
      </opc:Property>
    </opc:Children>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>Devices</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="Iec61850ConfigurableObjectType" BaseType="ua:BaseObjectType">
    <opc:Children>
      <opc:Property SymbolicName="Reference" DataType="ua:String" />
    </opc:Children>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="Iec61850RcbType" BaseType="Iec61850ConfigurableObjectType">
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>Iec61850DeviceType</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="Iec61850ServerType" BaseType="DeviceType">
    <opc:Children>
      <opc:Property SymbolicName="Host" DataType="ua:String" />
      <opc:Property SymbolicName="Port" DataType="ua:UInt16">
        <opc:DefaultValue>
          <uax:UInt16>102</uax:UInt16>
        </opc:DefaultValue>
      </opc:Property>
    </opc:Children>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>Devices</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <!-- MODBUS Devices -->

  <opc:DataType SymbolicName="ModbusLinkProtocol" BaseType="ua:Enumeration">
    <opc:Fields>
      <opc:Field Name="RTU" Identifier="0" />
      <opc:Field Name="ASCII" Identifier="1" />
      <opc:Field Name="TCP" Identifier="2" />
    </opc:Fields>
  </opc:DataType>

  <opc:ObjectType SymbolicName="ModbusLinkType" BaseType="LinkType">
    <opc:Children>
      <opc:Property SymbolicName="Protocol" DataType="ModbusLinkProtocol" />
      <opc:Property SymbolicName="RequestDelay" DataType="ua:UInt32" />
    </opc:Children>
  </opc:ObjectType>

  <opc:ObjectType SymbolicName="ModbusDeviceType" BaseType="DeviceType">
    <opc:Children>
      <opc:Property SymbolicName="Address" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>1</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="SendRetryCount" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>3</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
      <opc:Property SymbolicName="ResponseTimeout" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>1000</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
    </opc:Children>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>ModbusLinkType</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <!-- OPC Server -->

  <opc:ObjectType SymbolicName="OpcServerType" BaseType="DeviceType">
    <opc:Children>
      <opc:Property SymbolicName="MachineName" DataType="ua:LocalizedText" />
      <opc:Property SymbolicName="ProgId" DataType="ua:LocalizedText" />
    </opc:Children>
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>Devices</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

  <!-- Transmission Items -->

  <opc:Object SymbolicName="TransmissionItems" TypeDefinition="ua:FolderType">
    <opc:References>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>ua:Organizes</opc:ReferenceType>
        <opc:TargetId>ua:ObjectsFolder</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:Object>

  <opc:ReferenceType SymbolicName="HasTransmissionSource" BaseType="ua:NonHierarchicalReferences">
    <opc:Description>HasTransmissionSource.</opc:Description>
    <opc:InverseName>TransmissionSourceOf</opc:InverseName>
  </opc:ReferenceType>

  <opc:ReferenceType SymbolicName="HasTransmissionTarget" BaseType="ua:NonHierarchicalReferences">
    <opc:Description>HasTransmissionTarget.</opc:Description>
    <opc:InverseName>TransmissionTargetOf</opc:InverseName>
  </opc:ReferenceType>

  <opc:ObjectType SymbolicName="TransmissionItemType" BaseType="ua:BaseObjectType">
    <opc:Children>
      <opc:Property SymbolicName="SourceAddress" DataType="ua:UInt32">
        <opc:DefaultValue>
          <uax:UInt32>0</uax:UInt32>
        </opc:DefaultValue>
      </opc:Property>
    </opc:Children>
    <opc:References>
      <opc:Reference>
        <opc:ReferenceType>HasTransmissionSource</opc:ReferenceType>
        <opc:TargetId>ua:BaseVariableType</opc:TargetId>
      </opc:Reference>
      <opc:Reference>
        <opc:ReferenceType>HasTransmissionTarget</opc:ReferenceType>
        <opc:TargetId>DeviceType</opc:TargetId>
      </opc:Reference>
      <opc:Reference IsInverse="true">
        <opc:ReferenceType>scada:Creates</opc:ReferenceType>
        <opc:TargetId>TransmissionItems</opc:TargetId>
      </opc:Reference>
    </opc:References>
  </opc:ObjectType>

</opc:ModelDesign>